NODE_ENV=development
PORT=4000

# Cluster de MongoDB Atlas del proyecto (no un addon de base de datos de Railway)
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/rutacar

# API key compartida SOLO entre el servidor de Next.js (proxy) y este backend.
# Generar con: openssl rand -hex 32
BACKEND_API_KEY=

# Orígenes permitidos (LA-2026-017) — informativo mientras el único flujo público
# use el proxy server-to-server; relevante cuando un panel interno (Incrementos
# 04/07/08/09) llame a este backend directamente desde el navegador.
ALLOWED_ORIGINS=https://rutacarlandingnew-production.up.railway.app

RATE_LIMIT_WINDOW_MINUTES=60
RATE_LIMIT_MAX_REQUESTS=5

# Notificaciones por email (Resend). Sin RESEND_API_KEY/FROM_EMAIL, el envío se
# omite y solo queda registrado el intento (ver notification.service.ts).
# Obtener API key en https://resend.com/api-keys
RESEND_API_KEY=
# onboarding@resend.dev es el dominio de pruebas compartido de Resend: solo
# puede enviar hacia ADMIN_EMAIL (la cuenta dueña de la API key), no hacia
# cualquier destinatario — 403 en cualquier otro caso. Verificar un dominio
# propio de Ruta Car en resend.com/domains antes de DP-FINAL.
FROM_EMAIL=onboarding@resend.dev
# Correo del equipo comercial que recibe cada lead nuevo.
ADMIN_EMAIL=
